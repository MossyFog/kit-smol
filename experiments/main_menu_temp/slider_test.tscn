[sub_resource type="GDScript" id="GDScript_gsiyq"]
script/source = "extends Label

@onready var tooltip_theme = load(\"res://core/ui/tooltip_theme.tres\")

func _get_tooltip(at_position: Vector2) -> String:
	return text + str(at_position)

func _make_custom_tooltip(for_text: String) -> Object:
	var label = Label.new()
	label.text = for_text
	label.theme = tooltip_theme
	return label
"

